# Copy this file to backend/.env and fill in your values. backend/.env is git-ignored.
# spring-dotenv loads these into the Spring environment when the app starts from the backend/ folder.

# --- Translation ---
# Provider: deepl (default) | mymemory | local
TRANSLATION_PROVIDER=deepl

# DeepL API key. Get one free at https://www.deepl.com/pro-api (Free plan = 500,000 chars/month).
# Free keys end with ":fx" and are auto-routed to the free host; Pro keys use the paid host.
DEEPL_API_KEY=

# Optional DeepL host override (leave blank to auto-detect from the key suffix).
DEEPL_BASE_URL=

# Optional: only used when TRANSLATION_PROVIDER=mymemory. A valid email raises the free daily limit.
TRANSLATION_EMAIL=

# Comma-separated emails that should receive ADMIN role on registration/login.
ADMIN_EMAILS=

# --- Email verification ---
# Set to true in production after MAIL_* values are configured.
EMAIL_VERIFICATION_ENABLED=false
FRONTEND_BASE_URL=http://localhost:5173
EMAIL_VERIFICATION_FROM=no-reply@studybridge.local
EMAIL_VERIFICATION_TOKEN_EXPIRATION_HOURS=24

# SMTP settings used by email verification and optional reminder emails.
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
