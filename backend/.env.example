# Copy this file to backend/.env and fill in your values. backend/.env is git-ignored.
# spring-dotenv loads these into the Spring environment when the app starts from the backend/ folder.

# --- Translation ---
# Provider: deepl (default) | mymemory | local
TRANSLATION_PROVIDER=deepl

# DeepL API key. Get one free at https://www.deepl.com/pro-api (Free plan = 500,000 chars/month).
# Free keys end with ":fx" and are auto-routed to the free host; Pro keys use the paid host.
DEEPL_API_KEY=

# Optional DeepL host override (leave blank to auto-detect from the key suffix).
DEEPL_BASE_URL=

# Optional: only used when TRANSLATION_PROVIDER=mymemory. A valid email raises the free daily limit.
TRANSLATION_EMAIL=

# Comma-separated emails that should receive ADMIN role on registration/login.
ADMIN_EMAILS=

# --- Email verification ---
# Provider: smtp (default) | resend (HTTP API, recommended on Render)
EMAIL_VERIFICATION_ENABLED=false
EMAIL_VERIFICATION_PROVIDER=smtp
FRONTEND_BASE_URL=http://localhost:5173
EMAIL_VERIFICATION_FROM=no-reply@studybridge.local
EMAIL_VERIFICATION_TOKEN_EXPIRATION_HOURS=24

# Resend HTTP email provider. Use this on Render if direct SMTP times out.
RESEND_API_KEY=
RESEND_BASE_URL=https://api.resend.com/emails

# --- Email reminders ---
# Provider defaults to EMAIL_VERIFICATION_PROVIDER, so "resend" can cover both email features.
REMINDER_EMAIL_ENABLED=false
REMINDER_EMAIL_POLL_MS=60000
REMINDER_EMAIL_INITIAL_DELAY_MS=10000
# Optional overrides:
# REMINDER_EMAIL_PROVIDER=resend
# REMINDER_EMAIL_FROM=StudyBridge <noreply@your-verified-domain.com>

# SMTP settings used when an email feature uses the smtp provider.
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
MAIL_SMTP_STARTTLS_REQUIRED=true
MAIL_SMTP_CONNECTION_TIMEOUT=10000
MAIL_SMTP_TIMEOUT=10000
MAIL_SMTP_WRITE_TIMEOUT=10000
MAIL_DEBUG=false
